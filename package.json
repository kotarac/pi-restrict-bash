{
  "name": "pi-restrict-bash",
  "version": "1.0.4",
  "description": "Opinionated bash tool restrictions for Pi",
  "keywords": [
    "pi-package"
  ],
  "license": "GPL-2.0-only",
  "author": "Stipe Kotarac <stipe@kotarac.net>",
  "repository": {
    "type": "git",
    "url": "https://github.com/kotarac/pi-restrict-bash.git"
  },
  "type": "module",
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "files": [
    "extensions/restrict-bash.ts"
  ],
  "pi": {
    "extensions": [
      "./extensions/restrict-bash.ts"
    ]
  },
  "scripts": {
    "fmt": "biome check --write .",
    "test": "node --test",
    "tsc": "tsc -p tsconfig.json --noEmit",
    "//plumbing": "",
    "biome:migrate": "biome migrate --write",
    "//end": ""
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@mariozechner/pi-coding-agent": "*",
    "@types/node": "24",
    "typescript": "^6.0.2"
  }
}
